{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "uDOS Plugin Manifest",
  "type": "object",
  "required": [
    "name",
    "version",
    "entry"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "entry": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}